#include <stdio.h>

int max(int a, int b) {
    if(a > b)
        return a;
    else
        return b;
}

int knapsack( int n, int W, int weight[], int value[]) {
    int i, w;
    int DP[n+1][W+1];

    for(i = 0; i <= n; i++) {
        for(w = 0; w <= W; w++) {

            if(i == 0 || w == 0)
                DP[i][w] = 0;

            else if(weight[i-1] <= w)
                DP[i][w] = max(value[i-1] + DP[i-1][w-weight[i-1]],
                               DP[i-1][w]);

            else
                DP[i][w] = DP[i-1][w];
        }
    }

    return DP[n][W];
}

int main() {

    int value[] = {12, 10, 20, 15};
    int weight[] = {2, 1, 3, 2};
    int W = 5;
    int n = sizeof(value)/sizeof(value[0]);

    int result = knapsack(n, W, weight, value);

    printf("Maximum value in Knapsack = %d", result);

    return 0;
}